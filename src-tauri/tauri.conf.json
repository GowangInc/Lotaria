{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lotaria",
  "version": "0.3.1",
  "identifier": "com.lotaria.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5420"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/*",
      "models/*"
    ]
  }
}
